{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sw-wiki",
  "pages_build_output_dir": "dist",
  "compatibility_date": "2025-07-01",

  // D1 数据库绑定（首次部署需先在 CF Dashboard 创建 D1 数据库）
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "sw-wiki-db",
      "database_id": "def3bb2b-21a0-409c-b244-9e8de137747d"
    }
  ],

  // 环境变量
  "vars": {
    "JWT_SECRET": "" // 部署时通过 wrangler secret put JWT_SECRET 设置
  }
}
